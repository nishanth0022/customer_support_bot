# ── Customer Support Bot — Environment Configuration ──────────────────────────

# Refund auto-approve threshold (USD). Above this → human approval required.
REFUND_AUTO_APPROVE_LIMIT=100.0

# Retry / loop limits
MAX_RETRY_COUNT=3
MAX_CLARIFICATION_TURNS=3
MAX_LOOP_DETECTION_WINDOW=5

# Confidence below this → escalate to human
LOW_CONFIDENCE_THRESHOLD=0.6

# Session
SESSION_TTL_SECONDS=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/events.jsonl
# --- Groq LLM Configuration ---
GROQ_API_KEY=
LLM_MODEL=llama-3.1-70b-versatile
LLM_TEMPERATURE=0.1
